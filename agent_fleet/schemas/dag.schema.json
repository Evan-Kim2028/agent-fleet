{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FleetDag",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "tasks"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "models": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "properties": {
        "HIGH": {"type": "string"},
        "MED": {"type": "string"},
        "LOW": {"type": "string"}
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "depends_on", "complexity", "subtask_prompt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {"type": "string"}
          },
          "complexity": {
            "type": "string",
            "enum": ["HIGH", "MED", "LOW"]
          },
          "subtask_prompt": {"type": "string", "minLength": 1},
          "persona": {"type": "string"},
          "pipeline": {"type": "string"},
          "allowed_paths": {
            "type": "array",
            "items": {"type": "string"}
          },
          "skills": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
