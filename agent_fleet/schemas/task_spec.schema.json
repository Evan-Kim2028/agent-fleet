{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issue_number",
    "decomposition_decision",
    "decomposition_reason",
    "child_issues_proposed",
    "scope",
    "research_plan",
    "acceptance_criteria",
    "risk_tier",
    "critical_paths_touched",
    "coordination_spec"
  ],
  "properties": {
    "issue_number": {"type": "integer", "minimum": 1},
    "decomposition_decision": {
      "type": "string",
      "enum": ["single", "decompose", "dag", "rejected", "program"]
    },
    "decomposition_reason": {"type": "string"},
    "cross_cutting_acknowledged": {
      "type": "boolean",
      "description": "When true, the LLM has explicitly judged that allowed_paths crossing persona boundaries is acceptable for a single agent. Suppresses the mechanical override that would otherwise force decompose."
    },
    "child_issues_proposed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body", "persona"],
        "properties": {
          "title": {"type": "string"},
          "body": {"type": "string"},
          "persona": {"type": "string"},
          "allowed_paths": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "forbidden_paths"],
      "properties": {
        "allowed_paths": {"type": "array", "items": {"type": "string"}},
        "forbidden_paths": {"type": "array", "items": {"type": "string"}}
      }
    },
    "research_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "scope_paths", "needs_browser"],
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "scope_paths": {"type": "array", "items": {"type": "string"}},
          "needs_browser": {"type": "boolean"}
        }
      }
    },
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "risk_tier": {"type": "string", "enum": ["low", "medium", "high"]},
    "critical_paths_touched": {"type": "array", "items": {"type": "string"}},
    "coordination_spec": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "merge_order": {"type": "array", "items": {"type": "string"}},
            "schema_contracts_added": {"type": "array", "items": {"type": "string"}},
            "schema_contracts_removed": {"type": "array", "items": {"type": "string"}},
            "smoke_test_suggestion": {"type": ["string", "null"]},
            "shared_branch": {"type": ["string", "null"]},
            "interface_brief": {
              "oneOf": [
                {"type": "null"},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["http_route", "parquet_schema", "json_schema", "function_signature"]
                    },
                    "route": {"type": ["string", "null"]},
                    "request_shape": {"type": ["object", "null"]},
                    "response_shape": {"type": ["object", "null"]},
                    "fixture_path": {"type": ["string", "null"]},
                    "notes": {"type": ["string", "null"]}
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "program": {
      "type": ["string", "null"],
      "description": "Python orchestration program source (set only when decomposition_decision is 'program')"
    },
    "dag": {
      "type": "object",
      "description": "Cookbook-compatible DAG spec when decomposition_decision is dag",
      "additionalProperties": false,
      "required": ["title", "tasks"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "models": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "depends_on", "complexity", "subtask_prompt"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
              "depends_on": {"type": "array", "items": {"type": "string"}},
              "complexity": {"type": "string", "enum": ["HIGH", "MED", "LOW"]},
              "subtask_prompt": {"type": "string", "minLength": 1},
              "persona": {"type": "string"},
              "pipeline": {"type": "string"},
              "allowed_paths": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
